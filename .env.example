ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-ai-key-here
OPENAI_API_KEY=your-openai-key-here
MISTRAL_API_KEY=your-mistral-key-here
FMP_API_KEY=your-fmp-key-here
FINNHUB_API_KEY=your-finnhub-key-here
CORS_ORIGIN=http://localhost:5173
PORT=3001
NODE_ENV=development

# Supabase (server-side — never expose these in the frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase (frontend — safe to expose, restricted by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Observability (all optional — modules no-op when unset) ──────────────────
# Sentry — error monitoring. Get a DSN per project at sentry.io.
# The frontend and backend should each have their own Sentry project so the
# error streams stay separated.
SENTRY_DSN=                                       # backend (server/sentry.ts)
VITE_SENTRY_DSN=                                  # frontend (src/lib/sentry.ts)

# PostHog — product analytics. Get a project key at posthog.com.
# Only the frontend talks to PostHog; no server-side capture.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com        # change to https://eu.i.posthog.com for EU cloud
